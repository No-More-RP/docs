---
// Self-hosted fonts (bundled by Astro, no third-party request). Latin subset —
// covers FR + EN (Google's "latin" range includes œ/Œ).
import "@fontsource/inter/latin-400.css";
import "@fontsource/inter/latin-500.css";
import "@fontsource/inter/latin-600.css";
import "@fontsource/inter/latin-700.css";
import "@fontsource/jetbrains-mono/latin-400.css";
import "@fontsource/jetbrains-mono/latin-500.css";
import "@fontsource/jetbrains-mono/latin-600.css";

interface Props {
    title?: string;
    lang?: string;
    description?: string;
    /** Absolute URL of the Open Graph / Twitter card image. */
    image?: string;
    /** Absolute canonical URL of the page. */
    canonical?: string;
    /** Open Graph object type. */
    type?: "website" | "article";
    /** JSON-LD structured data — one object or several. */
    schema?: object | object[];
    /** hreflang alternates: [{ hreflang, href }] for the FR/EN versions. */
    alternates?: { hreflang: string; href: string }[];
}

const DEFAULT_DESC =
    "NoMoreRP — an object-oriented MVC gamemode base for nanos world, backed by dependency-free Lua packages for RPC, ORM, promises and i18n.";

const {
    title = "NoMoreRP — MVC roleplay framework for nanos world",
    lang = "fr",
    description = DEFAULT_DESC,
    image,
    canonical,
    type = "website",
    schema,
    alternates = [],
} = Astro.props;

const ogLocale = lang === "fr" ? "fr_FR" : "en_US";
const skipLabel = lang === "fr" ? "Aller au contenu" : "Skip to content";

const schemas = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
// Escape "<" so a stray "</script>" inside content can't break out of the tag.
const ld = (obj) => JSON.stringify(obj).replace(/</g, "\\u003c");
---

<!doctype html>
<html lang={lang}>
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="description" content={description} />
        {canonical && <link rel="canonical" href={canonical} />}
        {
            alternates.map((a) => (
                <link rel="alternate" hreflang={a.hreflang} href={a.href} />
            ))
        }
        <link
            rel="icon"
            type="image/png"
            sizes="32x32"
            href={`${import.meta.env.BASE_URL}favicon-32.png`}
        />
        <link
            rel="icon"
            type="image/png"
            sizes="16x16"
            href={`${import.meta.env.BASE_URL}favicon-16.png`}
        />
        <link
            rel="apple-touch-icon"
            href={`${import.meta.env.BASE_URL}apple-touch-icon.png`}
        />
        <link
            rel="manifest"
            href={`${import.meta.env.BASE_URL}site.webmanifest`}
        />
        <meta name="theme-color" content="#08090c" />
        <title>{title}</title>

        <!-- Open Graph -->
        <meta property="og:type" content={type} />
        <meta property="og:site_name" content="NoMoreRP" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:locale" content={ogLocale} />
        {canonical && <meta property="og:url" content={canonical} />}
        {image && <meta property="og:image" content={image} />}
        {image && <meta property="og:image:width" content="1200" />}
        {image && <meta property="og:image:height" content="630" />}
        {image && <meta property="og:image:alt" content={title} />}

        <!-- Twitter -->
        <meta
            name="twitter:card"
            content={image ? "summary_large_image" : "summary"}
        />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        {image && <meta name="twitter:image" content={image} />}

        <!-- JSON-LD structured data -->
        {
            schemas.map((s) => (
                <script type="application/ld+json" set:html={ld(s)} />
            ))
        }

    </head>
    <body>
        <a href="#main-content" class="skip-link">{skipLabel}</a>
        <slot />
    </body>
</html>

<style is:global>
    * {
        box-sizing: border-box;
    }
    html,
    body {
        margin: 0;
        padding: 0;
    }
    html {
        scroll-behavior: smooth;
    }
    body {
        background: #08090c;
    }
    ::selection {
        background: #3dd6f3;
        color: #08090c;
    }

    /* Keyboard focus ring — consistent, only for keyboard users. */
    :focus-visible {
        outline: 2px solid rgba(45, 200, 235, 0.75);
        outline-offset: 2px;
    }
    /* Skip-link targets (main/hero) receive focus but shouldn't show a ring. */
    [tabindex="-1"]:focus {
        outline: none;
    }

    /* Skip to content — hidden until focused. */
    .skip-link {
        position: fixed;
        top: 10px;
        left: 10px;
        z-index: 300;
        transform: translateY(-160%);
        background: #3dd6f3;
        color: #08090c;
        font-family: "Inter", system-ui, sans-serif;
        font-weight: 600;
        font-size: 14px;
        text-decoration: none;
        padding: 10px 16px;
        border-radius: 9px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
        transition: transform 0.18s ease;
    }
    .skip-link:focus-visible {
        transform: translateY(0);
        outline: none;
    }

    /* Respect reduced-motion: kill animations, transitions & smooth scroll. */
    @media (prefers-reduced-motion: reduce) {
        html {
            scroll-behavior: auto;
        }
        *,
        *::before,
        *::after {
            animation-duration: 0.01ms !important;
            animation-iteration-count: 1 !important;
            transition-duration: 0.01ms !important;
            scroll-behavior: auto !important;
        }
    }

    /* Thin, dark, subtle scrollbars everywhere (code panels, docs, sidebar…). */
    * {
        scrollbar-width: thin;
        scrollbar-color: rgba(255, 255, 255, 0.16) transparent;
    }
    ::-webkit-scrollbar {
        width: 10px;
        height: 10px;
    }
    ::-webkit-scrollbar-track {
        background: transparent;
    }
    ::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.14);
        border-radius: 8px;
        border: 2px solid transparent;
        background-clip: padding-box;
    }
    ::-webkit-scrollbar-thumb:hover {
        background: rgba(255, 255, 255, 0.26);
        background-clip: padding-box;
    }
    ::-webkit-scrollbar-corner {
        background: transparent;
    }
    @keyframes nmrpFloat {
        0%,
        100% {
            transform: translateY(0);
        }
        50% {
            transform: translateY(-8px);
        }
    }
    @keyframes nmrpBlink {
        0%,
        49% {
            opacity: 1;
        }
        50%,
        100% {
            opacity: 0;
        }
    }
</style>

---
import Base from "./Base.astro";
import LangSwitch from "../components/LangSwitch.astro";
import Search from "../components/Search.astro";
import { docsNav, docsUi } from "../data/docs-nav.js";
import { SITE_URL, DOCS_URL, DISCORD_URL } from "../data/site.js";

interface Heading {
    depth: number;
    slug: string;
    text: string;
}
interface Props {
    lang?: "fr" | "en";
    slug: string;
    title: string;
    description?: string;
    headings?: Heading[];
}

const { lang = "fr", slug, title, description, headings = [] } = Astro.props;
const isEn = lang === "en";
const ui = docsUi[lang];
const nav = docsNav[lang];

const base = import.meta.env.BASE_URL; // "/"
const clean = base.replace(/\/$/, ""); // ""
// The docs are served at the domain root (docs.nmrp.dev/introduction …).
const docsBase = isEn ? `${clean}/en` : clean;
// "Home" jumps back to the marketing site (nmrp.dev) — cross-domain in production.
const homeHref = isEn ? `${SITE_URL}/en` : SITE_URL || "/";
const href = (s: string) => `${docsBase}/${s}`;

// Language switch keeps you on the same page (both stay on the docs host).
const frDocHref = `${clean}/${slug}`;
const enDocHref = `${clean}/en/${slug}`;

// Flatten the nav for prev / next.
const flat = nav.flatMap((g) => g.items);
const idx = flat.findIndex((i) => i.slug === slug);
const prev = idx > 0 ? flat[idx - 1] : null;
const next = idx >= 0 && idx < flat.length - 1 ? flat[idx + 1] : null;

// Only h2 / h3 land in the "on this page" rail.
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);

const pageTitle = `${title} — NoMoreRP Docs`;

// Canonical URL + per-page Open Graph card (see src/pages/og/[...route].ts).
const canonical = `${DOCS_URL}/${isEn ? "en/" : ""}${slug}`;
const ogImage = `${DOCS_URL}/og/${isEn ? "en" : "fr"}/${slug}.png`;

// Labels for the injected "copy code" buttons.
const copyLabels = isEn
    ? { copy: "Copy", copied: "Copied!" }
    : { copy: "Copier", copied: "Copié !" };
---

<Base
    lang={lang}
    title={pageTitle}
    description={description}
    canonical={canonical}
    image={ogImage}
    type="article"
>
    <div class="docs">
        <div class="glow"></div>

        <!-- HEADER -->
        <header class="dnav">
            <div class="dnav-inner">
                <a href={homeHref} class="brand">
                    <img
                        src={`${base}nmrp_full_512.png`}
                        alt="NoMoreRP"
                        class="brand-logo"
                    />
                    <span class="brand-name"
                        >NoMore<span class="accent">RP</span></span
                    >
                    <span class="brand-docs">{ui.docsLabel}</span>
                </a>
                <div class="dnav-right">
                    <Search lang={lang} />
                    <a href={homeHref} class="dnav-lnk">{ui.backToSite}</a>
                    <LangSwitch
                        isEn={isEn}
                        frHref={frDocHref}
                        enHref={enDocHref}
                    />
                    <a
                        href={DISCORD_URL}
                        target="_blank"
                        rel="noopener"
                        class="icon-lnk icon-discord"
                        aria-label="Discord"
                    >
                        <svg
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            aria-hidden="true"
                            ><path
                                d="M20.317 4.3698a19.7913 19.7913 0 0 0-4.8851-1.5152.0741.0741 0 0 0-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 0 0-.0785-.037 19.7363 19.7363 0 0 0-4.8852 1.515.0699.0699 0 0 0-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 0 0 .0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 0 0 .0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 0 0-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 0 1-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 0 1 .0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 0 1 .0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 0 1-.0066.1276 12.2986 12.2986 0 0 1-1.873.8914.0766.0766 0 0 0-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 0 0 .0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 0 0 .0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 0 0-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9554 2.4189-2.1568 2.4189Z"
                            ></path></svg
                        >
                    </a>
                    <a
                        href="https://github.com/No-More-RP"
                        target="_blank"
                        rel="noopener"
                        class="icon-lnk"
                        aria-label="GitHub"
                    >
                        <svg
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            ><path
                                d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.5v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.8 18.3 5 18.3 5c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.6.8.5 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5z"
                            ></path></svg
                        >
                    </a>
                </div>
            </div>
        </header>

        <div class="dlayout">
            <!-- SIDEBAR -->
            <aside class="sidebar">
                <nav class="side-nav">
                    <!-- Quick links -->
                    <ul class="side-top">
                        <li>
                            <a href={homeHref} class="side-top-lnk">
                                <svg
                                    width="16"
                                    height="16"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="1.7"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    aria-hidden="true"
                                    ><path d="M3 9.5 12 3l9 6.5V21H3z"
                                    ></path><path d="M9 21v-6h6v6"></path></svg
                                >
                                <span>{ui.backToSite}</span>
                            </a>
                        </li>
                        <li>
                            <a
                                href={href("contributors")}
                                class={`side-top-lnk${slug === "contributors" ? " active" : ""}`}
                            >
                                <svg
                                    width="16"
                                    height="16"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="1.7"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    aria-hidden="true"
                                    ><path
                                        d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"
                                    ></path><circle cx="9" cy="7" r="4"
                                    ></circle><path
                                        d="M22 21v-2a4 4 0 0 0-3-3.87"
                                    ></path><path d="M16 3.13a4 4 0 0 1 0 7.75"
                                    ></path></svg
                                >
                                <span>{ui.contributors}</span>
                            </a>
                        </li>
                        <li>
                            <a
                                href="https://github.com/orgs/No-More-RP/projects/1"
                                target="_blank"
                                rel="noopener"
                                class="side-top-lnk"
                            >
                                <svg
                                    width="16"
                                    height="16"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="1.7"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    aria-hidden="true"
                                    ><rect
                                        x="3"
                                        y="3"
                                        width="18"
                                        height="18"
                                        rx="2"></rect><path d="M9 3v18M3 9h6"
                                    ></path></svg
                                >
                                <span>{ui.roadmap}</span>
                                <svg
                                    class="ext"
                                    width="12"
                                    height="12"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    aria-hidden="true"
                                    ><path d="M7 17 17 7M8 7h9v9"></path></svg
                                >
                            </a>
                        </li>
                    </ul>

                    <!-- Grouped nav (collapsible) -->
                    {
                        nav.map((group) => {
                            const open = group.items.some(
                                (i) => i.slug === slug,
                            );
                            return (
                                <div
                                    class={`side-group${open ? "" : " collapsed"}`}
                                >
                                    <button
                                        class="side-title"
                                        type="button"
                                        aria-expanded={open ? "true" : "false"}
                                    >
                                        <span>{group.group}</span>
                                        <svg
                                            class="chev"
                                            width="13"
                                            height="13"
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="2.2"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            aria-hidden="true"
                                        >
                                            <path d="M6 9l6 6 6-6" />
                                        </svg>
                                    </button>
                                    <ul class="side-list">
                                        {group.items.map((item) => (
                                            <li>
                                                <a
                                                    href={href(item.slug)}
                                                    class={`side-lnk${item.slug === slug ? " active" : ""}`}
                                                >
                                                    {item.label}
                                                </a>
                                            </li>
                                        ))}
                                    </ul>
                                </div>
                            );
                        })
                    }
                </nav>
            </aside>

            <!-- CONTENT -->
            <main class="content">
                <article class="prose" data-pagefind-body>
                    <slot />
                </article>

                <nav class="pager">
                    {
                        prev ? (
                            <a href={href(prev.slug)} class="pager-lnk prev">
                                <span class="pager-dir">← {ui.prev}</span>
                                <span class="pager-label">{prev.label}</span>
                            </a>
                        ) : (
                            <span />
                        )
                    }
                    {
                        next ? (
                            <a href={href(next.slug)} class="pager-lnk next">
                                <span class="pager-dir">{ui.next} →</span>
                                <span class="pager-label">{next.label}</span>
                            </a>
                        ) : (
                            <span />
                        )
                    }
                </nav>
            </main>

            <!-- ON THIS PAGE -->
            <aside class="toc">
                {
                    toc.length > 0 && (
                        <div class="toc-inner">
                            <p class="toc-title">{ui.onThisPage}</p>
                            <ul class="toc-list">
                                {toc.map((h) => (
                                    <li class={`toc-item depth-${h.depth}`}>
                                        <a href={`#${h.slug}`}>{h.text}</a>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    )
                }
            </aside>
        </div>
    </div>
</Base>

<style>
    .docs {
        color: #e7e9ee;
        font-family: "Inter", system-ui, sans-serif;
        min-height: 100vh;
        position: relative;
    }
    .accent {
        color: #3dd6f3;
    }
    .glow {
        position: absolute;
        top: -260px;
        left: 50%;
        transform: translateX(-50%);
        width: 1100px;
        height: 560px;
        background: radial-gradient(
            ellipse at center,
            rgba(45, 200, 235, 0.12),
            rgba(8, 9, 12, 0) 68%
        );
        pointer-events: none;
        z-index: 0;
    }

    /* HEADER */
    .dnav {
        position: sticky;
        top: 0;
        z-index: 50;
        backdrop-filter: blur(14px);
        background: rgba(8, 9, 12, 0.78);
        border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    }
    .dnav-inner {
        max-width: 1320px;
        margin: 0 auto;
        padding: 14px 28px;
        display: flex;
        align-items: center;
        gap: 20px;
    }
    .brand {
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        color: #e7e9ee;
    }
    .brand-logo {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        box-shadow: 0 0 18px rgba(45, 200, 235, 0.4);
    }
    .brand-name {
        font-family: "Inter", sans-serif;
        font-weight: 700;
        font-size: 17px;
        letter-spacing: -0.02em;
    }
    .brand-docs {
        font-family: "JetBrains Mono", monospace;
        font-size: 11px;
        color: #6b7280;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 6px;
        padding: 2px 7px;
        margin-left: 2px;
    }
    .dnav-right {
        margin-left: auto;
        display: flex;
        align-items: center;
        gap: 14px;
    }
    .dnav-lnk {
        color: #9098a6;
        text-decoration: none;
        font-size: 14px;
        font-weight: 500;
        transition: color 0.15s;
    }
    .dnav-lnk:hover {
        color: #e7e9ee;
    }
    .icon-lnk {
        display: flex;
        align-items: center;
        color: #9098a6;
        transition: color 0.15s;
    }
    .icon-lnk:hover {
        color: #e7e9ee;
    }
    .icon-discord:hover {
        color: #5865f2;
    }

    /* LAYOUT */
    .dlayout {
        max-width: 1320px;
        margin: 0 auto;
        padding: 0 28px;
        display: grid;
        grid-template-columns: 236px minmax(0, 1fr) 200px;
        gap: 44px;
        position: relative;
        z-index: 1;
    }

    /* SIDEBAR */
    .sidebar {
        position: sticky;
        top: 60px;
        align-self: start;
        height: calc(100vh - 60px);
        overflow-y: auto;
        padding: 36px 0 40px;
    }
    /* Quick links */
    .side-top {
        list-style: none;
        margin: 0 0 24px;
        padding: 0 0 22px;
        display: flex;
        flex-direction: column;
        gap: 2px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    }
    .side-top-lnk {
        display: flex;
        align-items: center;
        gap: 11px;
        text-decoration: none;
        color: #9098a6;
        font-size: 14px;
        font-weight: 500;
        padding: 7px 14px;
        border-radius: 8px;
        transition:
            color 0.15s,
            background 0.15s;
    }
    .side-top-lnk:hover {
        color: #e7e9ee;
        background: rgba(255, 255, 255, 0.03);
    }
    .side-top-lnk.active {
        color: #fff;
        background: rgba(45, 200, 235, 0.1);
    }
    .side-top-lnk.active svg {
        color: #3dd6f3;
    }
    .side-top-lnk svg {
        flex-shrink: 0;
    }
    .side-top-lnk .ext {
        margin-left: auto;
        color: #565d6b;
    }

    /* Grouped nav */
    .side-group {
        margin-bottom: 22px;
    }
    .side-group:last-child {
        margin-bottom: 0;
    }
    .side-title {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
        background: none;
        border: none;
        cursor: pointer;
        font-family: "Inter", sans-serif;
        font-size: 13px;
        font-weight: 600;
        color: #e7e9ee;
        text-align: left;
        padding: 6px 14px;
        margin: 0 0 6px;
    }
    .side-title .chev {
        flex-shrink: 0;
        color: #6b7280;
        transition: transform 0.2s ease;
    }
    .side-group.collapsed .chev {
        transform: rotate(-90deg);
    }
    .side-group.collapsed .side-list {
        display: none;
    }
    .side-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 2px;
        border-left: 1px solid rgba(255, 255, 255, 0.07);
    }
    .side-lnk {
        display: block;
        text-decoration: none;
        color: #8a92a0;
        font-size: 13.5px;
        line-height: 1.4;
        padding: 6px 14px;
        margin-left: -1px;
        border-left: 2px solid transparent;
        transition:
            color 0.15s ease,
            border-color 0.15s ease;
    }
    .side-lnk:hover {
        color: #e7e9ee;
        border-left-color: rgba(255, 255, 255, 0.2);
    }
    .side-lnk.active {
        color: #fff;
        border-left-color: #3dd6f3;
        font-weight: 600;
    }

    /* CONTENT */
    .content {
        min-width: 0;
        padding: 44px 0 80px;
    }

    /* PAGER */
    .pager {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        margin-top: 56px;
        padding-top: 28px;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
    }
    .pager-lnk {
        display: flex;
        flex-direction: column;
        gap: 4px;
        text-decoration: none;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 12px;
        padding: 14px 18px;
        min-width: 170px;
        transition:
            border-color 0.15s,
            background 0.15s;
    }
    .pager-lnk:hover {
        border-color: rgba(45, 200, 235, 0.4);
        background: rgba(45, 200, 235, 0.03);
    }
    .pager-lnk.next {
        text-align: right;
        margin-left: auto;
    }
    .pager-dir {
        font-family: "JetBrains Mono", monospace;
        font-size: 12px;
        color: #6b7280;
    }
    .pager-label {
        font-family: "Inter", sans-serif;
        font-weight: 600;
        font-size: 15px;
        color: #e7e9ee;
    }

    /* TOC */
    .toc {
        position: sticky;
        top: 60px;
        align-self: start;
        height: calc(100vh - 60px);
        overflow-y: auto;
        padding: 48px 0 40px;
    }
    .toc-title {
        font-family: "JetBrains Mono", monospace;
        font-size: 11px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #565d6b;
        margin: 0 0 12px;
    }
    .toc-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 7px;
        border-left: 1px solid rgba(255, 255, 255, 0.08);
    }
    .toc-item a {
        text-decoration: none;
        color: #8b93a1;
        font-size: 13px;
        line-height: 1.4;
        display: block;
        padding-left: 14px;
        margin-left: -1px;
        border-left: 2px solid transparent;
        transition:
            color 0.15s,
            border-color 0.15s;
    }
    .toc-item a:hover {
        color: #3dd6f3;
        border-left-color: #3dd6f3;
    }
    .toc-item.depth-3 a {
        padding-left: 26px;
        font-size: 12.5px;
        color: #6b7280;
    }
    .toc-item a.active {
        color: #3dd6f3;
        border-left-color: #3dd6f3;
    }

    @media (max-width: 1120px) {
        .dlayout {
            grid-template-columns: 220px minmax(0, 1fr);
        }
        .toc {
            display: none;
        }
    }
    @media (max-width: 820px) {
        .dlayout {
            grid-template-columns: 1fr;
            gap: 0;
        }
        .sidebar {
            position: static;
            height: auto;
            overflow: visible;
            padding: 20px 0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            display: flex;
            flex-wrap: wrap;
            gap: 8px 22px;
        }
        .side-group {
            margin-bottom: 8px;
        }
        .content {
            padding-top: 28px;
        }
        .dnav-lnk {
            display: none;
        }
    }
</style>

<!-- Prose styles for the rendered markdown. Global so they reach the injected HTML. -->
<style is:global>
    .prose {
        font-size: 15.5px;
        line-height: 1.72;
        color: #c3cad6;
        max-width: 760px;
    }
    .prose > :first-child {
        margin-top: 0;
    }

    .prose h1 {
        font-family: "Inter", sans-serif;
        font-weight: 700;
        font-size: 38px;
        line-height: 1.12;
        letter-spacing: -0.03em;
        color: #f2f4f8;
        margin: 0 0 8px;
        text-wrap: balance;
    }
    .prose h2 {
        font-family: "Inter", sans-serif;
        font-weight: 700;
        font-size: 25px;
        letter-spacing: -0.02em;
        color: #f2f4f8;
        margin: 52px 0 16px;
        padding-top: 8px;
        scroll-margin-top: 80px;
    }
    .prose h3 {
        font-family: "Inter", sans-serif;
        font-weight: 600;
        font-size: 18.5px;
        letter-spacing: -0.01em;
        color: #e7e9ee;
        margin: 34px 0 12px;
        scroll-margin-top: 80px;
    }
    .prose h2 + h3 {
        margin-top: 20px;
    }
    /* Hover anchor "#" on headings (injected by script). */
    .prose :is(h2, h3) {
        position: relative;
    }
    .prose .heading-anchor {
        margin-left: 8px;
        color: #4d5361;
        border-bottom: none;
        font-weight: 400;
        text-decoration: none;
        opacity: 0;
        transition:
            opacity 0.15s,
            color 0.15s;
    }
    .prose :is(h2, h3):hover .heading-anchor,
    .prose .heading-anchor:focus-visible {
        opacity: 1;
    }
    .prose .heading-anchor:hover {
        color: #3dd6f3;
    }

    /* The subtitle: a lead paragraph right after the H1. */
    .prose h1 + p {
        font-size: 18px;
        line-height: 1.6;
        color: #9098a6;
        margin: 0 0 8px;
    }

    .prose p {
        margin: 0 0 16px;
    }
    .prose a {
        color: #3dd6f3;
        text-decoration: none;
        border-bottom: 1px solid rgba(61, 214, 243, 0.28);
        transition: border-color 0.15s;
    }
    .prose a:hover {
        border-bottom-color: #3dd6f3;
    }
    /* Links wrapping inline code (e.g. package names): drop the underline so it
       doesn't cut across the rounded code pill — the pill is the affordance. */
    .prose a:has(> code) {
        border-bottom: none;
    }
    .prose a > code {
        color: #3dd6f3;
        border-color: rgba(45, 200, 235, 0.32);
        transition:
            background 0.15s,
            border-color 0.15s;
    }
    .prose a:hover > code {
        background: rgba(45, 200, 235, 0.16);
        border-color: rgba(45, 200, 235, 0.55);
    }
    .prose strong {
        color: #e7e9ee;
        font-weight: 650;
    }

    .prose ul,
    .prose ol {
        margin: 0 0 16px;
        padding-left: 22px;
    }
    .prose li {
        margin: 6px 0;
    }
    .prose li::marker {
        color: #3dd6f3;
    }

    /* Inline code */
    .prose :not(pre) > code {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.86em;
        color: #7fe7fb;
        background: rgba(45, 200, 235, 0.08);
        border: 1px solid rgba(45, 200, 235, 0.14);
        border-radius: 6px;
        padding: 1.5px 6px;
    }

    /* Code blocks (Shiki) */
    .prose pre {
        background: #0d0f14 !important;
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 14px;
        padding: 18px 20px;
        overflow-x: auto;
        margin: 0 0 20px;
        font-size: 13.5px;
        line-height: 1.7;
        box-shadow: 0 20px 50px -30px rgba(0, 0, 0, 0.7);
    }
    .prose pre code {
        font-family: "JetBrains Mono", monospace;
        background: none;
        border: none;
        padding: 0;
        font-size: inherit;
        color: inherit;
    }

    /* Copy button (wrapper + button are injected by the script below). */
    .prose .code-wrap {
        position: relative;
        margin: 0 0 20px;
    }
    .prose .code-wrap > pre {
        margin: 0;
    }
    .prose .copy-btn {
        position: absolute;
        top: 10px;
        right: 10px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 7px;
        color: #9098a6;
        font-family: "JetBrains Mono", monospace;
        font-size: 11.5px;
        line-height: 1;
        padding: 5px 8px;
        cursor: pointer;
        opacity: 0;
        transition:
            opacity 0.15s,
            color 0.15s,
            border-color 0.15s,
            background 0.15s;
    }
    .prose .copy-btn svg {
        flex-shrink: 0;
    }
    .prose .code-wrap:hover .copy-btn,
    .prose .copy-btn:focus-visible {
        opacity: 1;
    }
    .prose .copy-btn:hover {
        color: #e7e9ee;
        border-color: rgba(45, 200, 235, 0.4);
        background: rgba(45, 200, 235, 0.08);
    }
    .prose .copy-btn.copied {
        opacity: 1;
        color: #3dd6f3;
        border-color: rgba(45, 200, 235, 0.5);
    }
    @media (hover: none) {
        .prose .copy-btn {
            opacity: 1;
        }
    }

    /* Tables */
    .prose table {
        width: 100%;
        border-collapse: collapse;
        margin: 0 0 22px;
        font-size: 14px;
        display: block;
        overflow-x: auto;
    }
    .prose thead {
        text-align: left;
    }
    .prose th {
        font-family: "JetBrains Mono", monospace;
        font-size: 12px;
        letter-spacing: 0.03em;
        text-transform: uppercase;
        color: #8b93a1;
        font-weight: 600;
        padding: 10px 14px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.14);
        white-space: nowrap;
    }
    .prose td {
        padding: 10px 14px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        vertical-align: top;
    }
    .prose tbody tr:hover {
        background: rgba(255, 255, 255, 0.02);
    }

    /* Blockquote → callout */
    .prose blockquote {
        margin: 0 0 20px;
        padding: 14px 18px;
        border: 1px solid rgba(45, 200, 235, 0.22);
        border-left: 3px solid #3dd6f3;
        border-radius: 10px;
        background: rgba(45, 200, 235, 0.05);
        color: #b6bdc9;
    }
    .prose blockquote p {
        margin: 0;
    }
    .prose blockquote p + p {
        margin-top: 8px;
    }

    .prose hr {
        border: none;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        margin: 40px 0;
    }

    .prose img {
        max-width: 100%;
        border-radius: 12px;
    }
</style>

<script is:inline>
    // Sidebar: collapse / expand a group by clicking its header.
    document.querySelectorAll(".side-title").forEach((btn) => {
        btn.addEventListener("click", () => {
            const group = btn.closest(".side-group");
            if (!group) return;
            const collapsed = group.classList.toggle("collapsed");
            btn.setAttribute("aria-expanded", collapsed ? "false" : "true");
        });
    });
</script>

<script define:vars={{ labels: copyLabels }}>
    // Add a "copy" button to every code block in the article.
    const copyIcon =
        '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="11" height="11" rx="2"/><path d="M5 15V5a2 2 0 0 1 2-2h10"/></svg>';
    const checkIcon =
        '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>';

    document.querySelectorAll(".prose pre").forEach((pre) => {
        const code = pre.querySelector("code");
        if (!code) return;

        // Wrap so the button stays put while the code scrolls horizontally.
        const wrap = document.createElement("div");
        wrap.className = "code-wrap";
        pre.parentNode.insertBefore(wrap, pre);
        wrap.appendChild(pre);

        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "copy-btn";
        btn.setAttribute("aria-label", labels.copy);
        btn.innerHTML = copyIcon + "<span>" + labels.copy + "</span>";

        let timer;
        btn.addEventListener("click", async () => {
            try {
                await navigator.clipboard.writeText(code.textContent);
                btn.classList.add("copied");
                btn.innerHTML = checkIcon + "<span>" + labels.copied + "</span>";
                clearTimeout(timer);
                timer = setTimeout(() => {
                    btn.classList.remove("copied");
                    btn.innerHTML = copyIcon + "<span>" + labels.copy + "</span>";
                }, 1800);
            } catch (e) {
                /* clipboard unavailable (non-secure context) */
            }
        });

        wrap.appendChild(btn);
    });
</script>

<script is:inline>
    // Heading anchors + "on this page" scroll-spy.
    (function () {
        const headings = [
            ...document.querySelectorAll(".prose h2[id], .prose h3[id]"),
        ];
        if (!headings.length) return;

        const isFr = document.documentElement.lang === "fr";

        // 1. Append a hover "#" anchor to each heading.
        headings.forEach((h) => {
            const a = document.createElement("a");
            a.className = "heading-anchor";
            a.href = "#" + h.id;
            a.textContent = "#";
            a.setAttribute(
                "aria-label",
                isFr ? "Lien vers cette section" : "Link to this section",
            );
            a.addEventListener("click", () => {
                const url =
                    location.origin + location.pathname + "#" + h.id;
                if (navigator.clipboard) navigator.clipboard.writeText(url);
            });
            h.appendChild(a);
        });

        // 2. Scroll-spy: highlight the current section in the TOC.
        const links = new Map();
        document.querySelectorAll(".toc-list a").forEach((a) => {
            const href = a.getAttribute("href") || "";
            if (href.startsWith("#"))
                links.set(decodeURIComponent(href.slice(1)), a);
        });
        if (!links.size) return;

        let current = null;
        function setActive(id) {
            if (id === current) return;
            current = id;
            links.forEach((a) => a.classList.remove("active"));
            const a = links.get(id);
            if (a) a.classList.add("active");
        }

        let ticking = false;
        function onScroll() {
            if (ticking) return;
            ticking = true;
            requestAnimationFrame(() => {
                ticking = false;
                let active = headings[0];
                for (const h of headings) {
                    if (h.getBoundingClientRect().top <= 100) active = h;
                    else break;
                }
                setActive(active ? active.id : null);
            });
        }

        window.addEventListener("scroll", onScroll, { passive: true });
        onScroll();
    })();
</script>

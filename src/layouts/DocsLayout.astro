---
import Base from "./Base.astro";
import LangSwitch from "../components/LangSwitch.astro";
import { docsNav, docsUi } from "../data/docs-nav.js";
import { SITE_URL, DOCS_URL, DISCORD_URL } from "../data/site.js";

interface Heading {
    depth: number;
    slug: string;
    text: string;
}
interface Props {
    lang?: "fr" | "en";
    slug: string;
    title: string;
    description?: string;
    headings?: Heading[];
}

const { lang = "fr", slug, title, description, headings = [] } = Astro.props;
const isEn = lang === "en";
const ui = docsUi[lang];
const nav = docsNav[lang];

const base = import.meta.env.BASE_URL; // "/"
const clean = base.replace(/\/$/, ""); // ""
// The docs are served at the domain root (docs.nmrp.dev/introduction …).
const docsBase = isEn ? `${clean}/en` : clean;
// "Home" jumps back to the marketing site (nmrp.dev) — cross-domain in production.
const homeHref = isEn ? `${SITE_URL}/en` : SITE_URL || "/";
const href = (s: string) => `${docsBase}/${s}`;

// Language switch keeps you on the same page (both stay on the docs host).
const frDocHref = `${clean}/${slug}`;
const enDocHref = `${clean}/en/${slug}`;

// Flatten the nav for prev / next.
const flat = nav.flatMap((g) => g.items);
const idx = flat.findIndex((i) => i.slug === slug);
const prev = idx > 0 ? flat[idx - 1] : null;
const next = idx >= 0 && idx < flat.length - 1 ? flat[idx + 1] : null;

// Only h2 / h3 land in the "on this page" rail.
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);

const pageTitle = `${title} — NoMoreRP Docs`;

// Canonical URL + per-page Open Graph card (see src/pages/og/[...route].ts).
const canonical = `${DOCS_URL}/${isEn ? "en/" : ""}${slug}`;
const ogImage = `${DOCS_URL}/og/${isEn ? "en" : "fr"}/${slug}.png`;
---

<Base
    lang={lang}
    title={pageTitle}
    description={description}
    canonical={canonical}
    image={ogImage}
    type="article"
>
    <div class="docs">
        <div class="glow"></div>

        <!-- HEADER -->
        <header class="dnav">
            <div class="dnav-inner">
                <a href={homeHref} class="brand">
                    <img
                        src={`${base}nmrp_full_512.png`}
                        alt="NoMoreRP"
                        class="brand-logo"
                    />
                    <span class="brand-name"
                        >NoMore<span class="accent">RP</span></span
                    >
                    <span class="brand-docs">{ui.docsLabel}</span>
                </a>
                <div class="dnav-right">
                    <a href={homeHref} class="dnav-lnk">{ui.backToSite}</a>
                    <LangSwitch
                        isEn={isEn}
                        frHref={frDocHref}
                        enHref={enDocHref}
                    />
                    <a
                        href={DISCORD_URL}
                        target="_blank"
                        rel="noopener"
                        class="icon-lnk icon-discord"
                        aria-label="Discord"
                    >
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.317 4.369A19.79 19.79 0 0 0 15.885 3c-.21.375-.45.885-.617 1.287a18.27 18.27 0 0 0-5.535 0C9.567 3.885 9.32 3.375 9.11 3a19.7 19.7 0 0 0-4.433 1.369C1.99 8.36 1.26 12.25 1.624 16.08a19.9 19.9 0 0 0 6.073 3.058c.492-.672.93-1.386 1.307-2.136a12.9 12.9 0 0 1-2.06-.99c.173-.126.342-.258.505-.394a14.2 14.2 0 0 0 12.1 0c.166.14.335.272.505.394-.657.388-1.35.72-2.06.99.377.75.815 1.463 1.307 2.135a19.85 19.85 0 0 0 6.075-3.058c.427-4.44-.729-8.29-3.061-11.71ZM8.02 13.75c-1.183 0-2.157-1.085-2.157-2.42 0-1.333.955-2.42 2.157-2.42 1.21 0 2.176 1.096 2.157 2.42 0 1.335-.955 2.42-2.157 2.42Zm7.96 0c-1.183 0-2.157-1.085-2.157-2.42 0-1.333.955-2.42 2.157-2.42 1.21 0 2.176 1.096 2.157 2.42 0 1.335-.947 2.42-2.157 2.42Z"/></svg>
                    </a>
                    <a
                        href="https://github.com/No-More-RP"
                        target="_blank"
                        rel="noopener"
                        class="icon-lnk"
                        aria-label="GitHub"
                    >
                        <svg
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            ><path
                                d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.5v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.8 18.3 5 18.3 5c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.6.8.5 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5z"
                            ></path></svg
                        >
                    </a>
                </div>
            </div>
        </header>

        <div class="dlayout">
            <!-- SIDEBAR -->
            <aside class="sidebar">
                <nav class="side-nav">
                    {
                        nav.map((group) => (
                            <div class="side-group">
                                <p class="side-title">{group.group}</p>
                                <ul class="side-list">
                                    {group.items.map((item) => (
                                        <li>
                                            <a
                                                href={href(item.slug)}
                                                class={`side-lnk${item.slug === slug ? " active" : ""}`}
                                            >
                                                {item.label}
                                            </a>
                                        </li>
                                    ))}
                                </ul>
                            </div>
                        ))
                    }
                </nav>
            </aside>

            <!-- CONTENT -->
            <main class="content">
                <article class="prose">
                    <slot />
                </article>

                <nav class="pager">
                    {
                        prev ? (
                            <a href={href(prev.slug)} class="pager-lnk prev">
                                <span class="pager-dir">← {ui.prev}</span>
                                <span class="pager-label">{prev.label}</span>
                            </a>
                        ) : (
                            <span />
                        )
                    }
                    {
                        next ? (
                            <a href={href(next.slug)} class="pager-lnk next">
                                <span class="pager-dir">{ui.next} →</span>
                                <span class="pager-label">{next.label}</span>
                            </a>
                        ) : (
                            <span />
                        )
                    }
                </nav>
            </main>

            <!-- ON THIS PAGE -->
            <aside class="toc">
                {
                    toc.length > 0 && (
                        <div class="toc-inner">
                            <p class="toc-title">{ui.onThisPage}</p>
                            <ul class="toc-list">
                                {toc.map((h) => (
                                    <li class={`toc-item depth-${h.depth}`}>
                                        <a href={`#${h.slug}`}>{h.text}</a>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    )
                }
            </aside>
        </div>
    </div>
</Base>

<style>
    .docs {
        color: #e7e9ee;
        font-family: "Inter", system-ui, sans-serif;
        min-height: 100vh;
        position: relative;
    }
    .accent {
        color: #3dd6f3;
    }
    .glow {
        position: absolute;
        top: -260px;
        left: 50%;
        transform: translateX(-50%);
        width: 1100px;
        height: 560px;
        background: radial-gradient(
            ellipse at center,
            rgba(45, 200, 235, 0.12),
            rgba(8, 9, 12, 0) 68%
        );
        pointer-events: none;
        z-index: 0;
    }

    /* HEADER */
    .dnav {
        position: sticky;
        top: 0;
        z-index: 50;
        backdrop-filter: blur(14px);
        background: rgba(8, 9, 12, 0.78);
        border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    }
    .dnav-inner {
        max-width: 1320px;
        margin: 0 auto;
        padding: 14px 28px;
        display: flex;
        align-items: center;
        gap: 20px;
    }
    .brand {
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        color: #e7e9ee;
    }
    .brand-logo {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        box-shadow: 0 0 18px rgba(45, 200, 235, 0.4);
    }
    .brand-name {
        font-family: "Inter", sans-serif;
        font-weight: 700;
        font-size: 17px;
        letter-spacing: -0.02em;
    }
    .brand-docs {
        font-family: "JetBrains Mono", monospace;
        font-size: 11px;
        color: #6b7280;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 6px;
        padding: 2px 7px;
        margin-left: 2px;
    }
    .dnav-right {
        margin-left: auto;
        display: flex;
        align-items: center;
        gap: 14px;
    }
    .dnav-lnk {
        color: #9098a6;
        text-decoration: none;
        font-size: 14px;
        font-weight: 500;
        transition: color 0.15s;
    }
    .dnav-lnk:hover {
        color: #e7e9ee;
    }
    .icon-lnk {
        display: flex;
        align-items: center;
        color: #9098a6;
        transition: color 0.15s;
    }
    .icon-lnk:hover {
        color: #e7e9ee;
    }
    .icon-discord:hover {
        color: #5865f2;
    }

    /* LAYOUT */
    .dlayout {
        max-width: 1320px;
        margin: 0 auto;
        padding: 0 28px;
        display: grid;
        grid-template-columns: 236px minmax(0, 1fr) 200px;
        gap: 44px;
        position: relative;
        z-index: 1;
    }

    /* SIDEBAR */
    .sidebar {
        position: sticky;
        top: 60px;
        align-self: start;
        height: calc(100vh - 60px);
        overflow-y: auto;
        padding: 36px 0 40px;
    }
    .side-group {
        margin-bottom: 28px;
    }
    .side-group:last-child {
        margin-bottom: 0;
    }
    .side-title {
        font-family: "JetBrains Mono", monospace;
        font-size: 10.5px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #4d5361;
        margin: 0 0 8px;
        padding: 0 14px;
    }
    .side-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 2px;
        border-left: 1px solid rgba(255, 255, 255, 0.06);
    }
    .side-lnk {
        display: block;
        text-decoration: none;
        color: #8a92a0;
        font-size: 13.5px;
        line-height: 1.4;
        padding: 6px 14px;
        margin-left: -1px;
        border-left: 2px solid transparent;
        transition:
            color 0.15s ease,
            border-color 0.15s ease;
    }
    .side-lnk:hover {
        color: #e7e9ee;
        border-left-color: rgba(255, 255, 255, 0.2);
    }
    .side-lnk.active {
        color: #e7e9ee;
        border-left-color: rgba(255, 255, 255, 0.55);
        font-weight: 600;
    }

    /* CONTENT */
    .content {
        min-width: 0;
        padding: 44px 0 80px;
    }

    /* PAGER */
    .pager {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        margin-top: 56px;
        padding-top: 28px;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
    }
    .pager-lnk {
        display: flex;
        flex-direction: column;
        gap: 4px;
        text-decoration: none;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 12px;
        padding: 14px 18px;
        min-width: 170px;
        transition:
            border-color 0.15s,
            background 0.15s;
    }
    .pager-lnk:hover {
        border-color: rgba(45, 200, 235, 0.4);
        background: rgba(45, 200, 235, 0.03);
    }
    .pager-lnk.next {
        text-align: right;
        margin-left: auto;
    }
    .pager-dir {
        font-family: "JetBrains Mono", monospace;
        font-size: 12px;
        color: #6b7280;
    }
    .pager-label {
        font-family: "Inter", sans-serif;
        font-weight: 600;
        font-size: 15px;
        color: #e7e9ee;
    }

    /* TOC */
    .toc {
        position: sticky;
        top: 60px;
        align-self: start;
        height: calc(100vh - 60px);
        overflow-y: auto;
        padding: 48px 0 40px;
    }
    .toc-title {
        font-family: "JetBrains Mono", monospace;
        font-size: 11px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #565d6b;
        margin: 0 0 12px;
    }
    .toc-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 7px;
        border-left: 1px solid rgba(255, 255, 255, 0.08);
    }
    .toc-item a {
        text-decoration: none;
        color: #8b93a1;
        font-size: 13px;
        line-height: 1.4;
        display: block;
        padding-left: 14px;
        margin-left: -1px;
        border-left: 2px solid transparent;
        transition:
            color 0.15s,
            border-color 0.15s;
    }
    .toc-item a:hover {
        color: #3dd6f3;
        border-left-color: #3dd6f3;
    }
    .toc-item.depth-3 a {
        padding-left: 26px;
        font-size: 12.5px;
        color: #6b7280;
    }

    @media (max-width: 1120px) {
        .dlayout {
            grid-template-columns: 220px minmax(0, 1fr);
        }
        .toc {
            display: none;
        }
    }
    @media (max-width: 820px) {
        .dlayout {
            grid-template-columns: 1fr;
            gap: 0;
        }
        .sidebar {
            position: static;
            height: auto;
            overflow: visible;
            padding: 20px 0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            display: flex;
            flex-wrap: wrap;
            gap: 8px 22px;
        }
        .side-group {
            margin-bottom: 8px;
        }
        .content {
            padding-top: 28px;
        }
        .dnav-lnk {
            display: none;
        }
    }
</style>

<!-- Prose styles for the rendered markdown. Global so they reach the injected HTML. -->
<style is:global>
    .prose {
        font-size: 15.5px;
        line-height: 1.72;
        color: #c3cad6;
        max-width: 760px;
    }
    .prose > :first-child {
        margin-top: 0;
    }

    .prose h1 {
        font-family: "Inter", sans-serif;
        font-weight: 700;
        font-size: 38px;
        line-height: 1.12;
        letter-spacing: -0.03em;
        color: #f2f4f8;
        margin: 0 0 8px;
        text-wrap: balance;
    }
    .prose h2 {
        font-family: "Inter", sans-serif;
        font-weight: 700;
        font-size: 25px;
        letter-spacing: -0.02em;
        color: #f2f4f8;
        margin: 52px 0 16px;
        padding-top: 8px;
        scroll-margin-top: 80px;
    }
    .prose h3 {
        font-family: "Inter", sans-serif;
        font-weight: 600;
        font-size: 18.5px;
        letter-spacing: -0.01em;
        color: #e7e9ee;
        margin: 34px 0 12px;
        scroll-margin-top: 80px;
    }
    .prose h2 + h3 {
        margin-top: 20px;
    }

    /* The subtitle: a lead paragraph right after the H1. */
    .prose h1 + p {
        font-size: 18px;
        line-height: 1.6;
        color: #9098a6;
        margin: 0 0 8px;
    }

    .prose p {
        margin: 0 0 16px;
    }
    .prose a {
        color: #3dd6f3;
        text-decoration: none;
        border-bottom: 1px solid rgba(61, 214, 243, 0.28);
        transition: border-color 0.15s;
    }
    .prose a:hover {
        border-bottom-color: #3dd6f3;
    }
    .prose strong {
        color: #e7e9ee;
        font-weight: 650;
    }

    .prose ul,
    .prose ol {
        margin: 0 0 16px;
        padding-left: 22px;
    }
    .prose li {
        margin: 6px 0;
    }
    .prose li::marker {
        color: #3dd6f3;
    }

    /* Inline code */
    .prose :not(pre) > code {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.86em;
        color: #7fe7fb;
        background: rgba(45, 200, 235, 0.08);
        border: 1px solid rgba(45, 200, 235, 0.14);
        border-radius: 6px;
        padding: 1.5px 6px;
    }

    /* Code blocks (Shiki) */
    .prose pre {
        background: #0d0f14 !important;
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 14px;
        padding: 18px 20px;
        overflow-x: auto;
        margin: 0 0 20px;
        font-size: 13.5px;
        line-height: 1.7;
        box-shadow: 0 20px 50px -30px rgba(0, 0, 0, 0.7);
    }
    .prose pre code {
        font-family: "JetBrains Mono", monospace;
        background: none;
        border: none;
        padding: 0;
        font-size: inherit;
        color: inherit;
    }

    /* Tables */
    .prose table {
        width: 100%;
        border-collapse: collapse;
        margin: 0 0 22px;
        font-size: 14px;
        display: block;
        overflow-x: auto;
    }
    .prose thead {
        text-align: left;
    }
    .prose th {
        font-family: "JetBrains Mono", monospace;
        font-size: 12px;
        letter-spacing: 0.03em;
        text-transform: uppercase;
        color: #8b93a1;
        font-weight: 600;
        padding: 10px 14px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.14);
        white-space: nowrap;
    }
    .prose td {
        padding: 10px 14px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        vertical-align: top;
    }
    .prose tbody tr:hover {
        background: rgba(255, 255, 255, 0.02);
    }

    /* Blockquote → callout */
    .prose blockquote {
        margin: 0 0 20px;
        padding: 14px 18px;
        border: 1px solid rgba(45, 200, 235, 0.22);
        border-left: 3px solid #3dd6f3;
        border-radius: 10px;
        background: rgba(45, 200, 235, 0.05);
        color: #b6bdc9;
    }
    .prose blockquote p {
        margin: 0;
    }
    .prose blockquote p + p {
        margin-top: 8px;
    }

    .prose hr {
        border: none;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        margin: 40px 0;
    }

    .prose img {
        max-width: 100%;
        border-radius: 12px;
    }
</style>

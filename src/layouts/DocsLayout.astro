---
import Base from './Base.astro';
import { docsNav, docsUi } from '../data/docs-nav.js';

interface Heading { depth: number; slug: string; text: string; }
interface Props {
  lang?: 'fr' | 'en';
  slug: string;
  title: string;
  description?: string;
  headings?: Heading[];
}

const { lang = 'fr', slug, title, description, headings = [] } = Astro.props;
const isEn = lang === 'en';
const ui = docsUi[lang];
const nav = docsNav[lang];

const base = import.meta.env.BASE_URL;              // "/"
const clean = base.replace(/\/$/, '');              // ""
const docsBase = isEn ? `${clean}/en/docs` : `${clean}/docs`;
const homeHref = isEn ? `${clean}/en` : (base || '/');
const href = (s: string) => `${docsBase}/${s}`;

// Language switch keeps you on the same page.
const otherHref = isEn ? `${clean}/docs/${slug}` : `${clean}/en/docs/${slug}`;

// Flatten the nav for prev / next.
const flat = nav.flatMap((g) => g.items);
const idx = flat.findIndex((i) => i.slug === slug);
const prev = idx > 0 ? flat[idx - 1] : null;
const next = idx >= 0 && idx < flat.length - 1 ? flat[idx + 1] : null;

// Only h2 / h3 land in the "on this page" rail.
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);

const pageTitle = `${title} — NoMoreRP Docs`;
---

<Base lang={lang} title={pageTitle}>
  <div class="docs">
    <div class="glow"></div>

    <!-- HEADER -->
    <header class="dnav">
      <div class="dnav-inner">
        <a href={homeHref} class="brand">
          <img src={`${base}nmrp_full_512.png`} alt="NoMoreRP" class="brand-logo" />
          <span class="brand-name">NoMore<span class="accent">RP</span></span>
          <span class="brand-docs">{ui.docsLabel}</span>
        </a>
        <div class="dnav-right">
          <a href={homeHref} class="dnav-lnk">{ui.backToSite}</a>
          <div class="lang-toggle">
            <a href={isEn ? otherHref : `${clean}/en/docs/${slug}`} class="lang-btn" style={`background:${isEn ? 'transparent' : '#3dd6f3'};color:${isEn ? '#9098a6' : '#08090c'};`}>FR</a>
            <a href={isEn ? `${clean}/docs/${slug}` : otherHref} class="lang-btn" style={`background:${isEn ? '#3dd6f3' : 'transparent'};color:${isEn ? '#08090c' : '#9098a6'};`}>EN</a>
          </div>
          <a href="https://github.com/No-More-RP" target="_blank" rel="noopener" class="icon-lnk" aria-label="GitHub">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.5v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.8 18.3 5 18.3 5c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.6.8.5 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5z"/></svg>
          </a>
        </div>
      </div>
    </header>

    <div class="dlayout">
      <!-- SIDEBAR -->
      <aside class="sidebar">
        <nav class="side-nav">
          {nav.map((group) => (
            <div class="side-group">
              <p class="side-title">{group.group}</p>
              <ul class="side-list">
                {group.items.map((item) => (
                  <li>
                    <a href={href(item.slug)} class={`side-lnk${item.slug === slug ? ' active' : ''}`}>{item.label}</a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </nav>
      </aside>

      <!-- CONTENT -->
      <main class="content">
        <article class="prose">
          <slot />
        </article>

        <nav class="pager">
          {prev ? (
            <a href={href(prev.slug)} class="pager-lnk prev">
              <span class="pager-dir">← {ui.prev}</span>
              <span class="pager-label">{prev.label}</span>
            </a>
          ) : <span></span>}
          {next ? (
            <a href={href(next.slug)} class="pager-lnk next">
              <span class="pager-dir">{ui.next} →</span>
              <span class="pager-label">{next.label}</span>
            </a>
          ) : <span></span>}
        </nav>
      </main>

      <!-- ON THIS PAGE -->
      <aside class="toc">
        {toc.length > 0 && (
          <div class="toc-inner">
            <p class="toc-title">{ui.onThisPage}</p>
            <ul class="toc-list">
              {toc.map((h) => (
                <li class={`toc-item depth-${h.depth}`}>
                  <a href={`#${h.slug}`}>{h.text}</a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </aside>
    </div>
  </div>
</Base>

<style>
  .docs { color:#e7e9ee; font-family:'Manrope',system-ui,sans-serif; min-height:100vh; position:relative; }
  .accent { color:#3dd6f3; }
  .glow { position:absolute; top:-260px; left:50%; transform:translateX(-50%); width:1100px; height:560px; background:radial-gradient(ellipse at center, rgba(45,200,235,0.12), rgba(8,9,12,0) 68%); pointer-events:none; z-index:0; }

  /* HEADER */
  .dnav { position:sticky; top:0; z-index:50; backdrop-filter:blur(14px); background:rgba(8,9,12,0.78); border-bottom:1px solid rgba(255,255,255,0.07); }
  .dnav-inner { max-width:1320px; margin:0 auto; padding:14px 28px; display:flex; align-items:center; gap:20px; }
  .brand { display:flex; align-items:center; gap:10px; text-decoration:none; color:#e7e9ee; }
  .brand-logo { width:30px; height:30px; border-radius:8px; box-shadow:0 0 18px rgba(45,200,235,0.4); }
  .brand-name { font-family:'Space Grotesk',sans-serif; font-weight:700; font-size:17px; letter-spacing:-0.02em; }
  .brand-docs { font-family:'JetBrains Mono',monospace; font-size:11px; color:#6b7280; border:1px solid rgba(255,255,255,0.12); border-radius:6px; padding:2px 7px; margin-left:2px; }
  .dnav-right { margin-left:auto; display:flex; align-items:center; gap:16px; }
  .dnav-lnk { color:#9098a6; text-decoration:none; font-size:14px; font-weight:500; transition:color .15s; }
  .dnav-lnk:hover { color:#e7e9ee; }
  .lang-toggle { display:flex; border:1px solid rgba(255,255,255,0.1); border-radius:8px; overflow:hidden; font-family:'JetBrains Mono',monospace; font-size:12px; }
  .lang-btn { padding:5px 10px; text-decoration:none; line-height:1.5; }
  .icon-lnk { display:flex; align-items:center; color:#9098a6; transition:color .15s; }
  .icon-lnk:hover { color:#e7e9ee; }

  /* LAYOUT */
  .dlayout { max-width:1320px; margin:0 auto; padding:0 28px; display:grid; grid-template-columns:236px minmax(0,1fr) 200px; gap:44px; position:relative; z-index:1; }

  /* SIDEBAR */
  .sidebar { position:sticky; top:60px; align-self:start; height:calc(100vh - 60px); overflow-y:auto; padding:36px 0 40px; }
  .side-group { margin-bottom:26px; }
  .side-title { font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; text-transform:uppercase; color:#565d6b; margin:0 0 10px; }
  .side-list { list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:1px; }
  .side-lnk { display:block; text-decoration:none; color:#9098a6; font-size:14px; padding:6px 12px; border-radius:8px; border-left:2px solid transparent; transition:color .15s, background .15s; }
  .side-lnk:hover { color:#e7e9ee; background:rgba(255,255,255,0.03); }
  .side-lnk.active { color:#3dd6f3; background:rgba(45,200,235,0.08); border-left-color:#3dd6f3; font-weight:600; }

  /* CONTENT */
  .content { min-width:0; padding:44px 0 80px; }

  /* PAGER */
  .pager { display:flex; justify-content:space-between; gap:16px; margin-top:56px; padding-top:28px; border-top:1px solid rgba(255,255,255,0.08); }
  .pager-lnk { display:flex; flex-direction:column; gap:4px; text-decoration:none; border:1px solid rgba(255,255,255,0.08); border-radius:12px; padding:14px 18px; min-width:170px; transition:border-color .15s, background .15s; }
  .pager-lnk:hover { border-color:rgba(45,200,235,0.4); background:rgba(45,200,235,0.03); }
  .pager-lnk.next { text-align:right; margin-left:auto; }
  .pager-dir { font-family:'JetBrains Mono',monospace; font-size:12px; color:#6b7280; }
  .pager-label { font-family:'Space Grotesk',sans-serif; font-weight:600; font-size:15px; color:#e7e9ee; }

  /* TOC */
  .toc { position:sticky; top:60px; align-self:start; height:calc(100vh - 60px); overflow-y:auto; padding:48px 0 40px; }
  .toc-title { font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; text-transform:uppercase; color:#565d6b; margin:0 0 12px; }
  .toc-list { list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:7px; border-left:1px solid rgba(255,255,255,0.08); }
  .toc-item a { text-decoration:none; color:#8b93a1; font-size:13px; line-height:1.4; display:block; padding-left:14px; margin-left:-1px; border-left:2px solid transparent; transition:color .15s, border-color .15s; }
  .toc-item a:hover { color:#3dd6f3; border-left-color:#3dd6f3; }
  .toc-item.depth-3 a { padding-left:26px; font-size:12.5px; color:#6b7280; }

  @media (max-width:1120px) {
    .dlayout { grid-template-columns:220px minmax(0,1fr); }
    .toc { display:none; }
  }
  @media (max-width:820px) {
    .dlayout { grid-template-columns:1fr; gap:0; }
    .sidebar { position:static; height:auto; overflow:visible; padding:20px 0; border-bottom:1px solid rgba(255,255,255,0.08); display:flex; flex-wrap:wrap; gap:8px 22px; }
    .side-group { margin-bottom:8px; }
    .content { padding-top:28px; }
    .dnav-lnk { display:none; }
  }
</style>

<!-- Prose styles for the rendered markdown. Global so they reach the injected HTML. -->
<style is:global>
  .prose { font-size:15.5px; line-height:1.72; color:#c3cad6; max-width:760px; }
  .prose > :first-child { margin-top:0; }

  .prose h1 { font-family:'Space Grotesk',sans-serif; font-weight:700; font-size:38px; line-height:1.12; letter-spacing:-0.03em; color:#f2f4f8; margin:0 0 8px; text-wrap:balance; }
  .prose h2 { font-family:'Space Grotesk',sans-serif; font-weight:700; font-size:25px; letter-spacing:-0.02em; color:#f2f4f8; margin:52px 0 16px; padding-top:8px; scroll-margin-top:80px; }
  .prose h3 { font-family:'Space Grotesk',sans-serif; font-weight:600; font-size:18.5px; letter-spacing:-0.01em; color:#e7e9ee; margin:34px 0 12px; scroll-margin-top:80px; }
  .prose h2 + h3 { margin-top:20px; }

  /* The subtitle: a lead paragraph right after the H1. */
  .prose h1 + p { font-size:18px; line-height:1.6; color:#9098a6; margin:0 0 8px; }

  .prose p { margin:0 0 16px; }
  .prose a { color:#3dd6f3; text-decoration:none; border-bottom:1px solid rgba(61,214,243,0.28); transition:border-color .15s; }
  .prose a:hover { border-bottom-color:#3dd6f3; }
  .prose strong { color:#e7e9ee; font-weight:650; }

  .prose ul, .prose ol { margin:0 0 16px; padding-left:22px; }
  .prose li { margin:6px 0; }
  .prose li::marker { color:#3dd6f3; }

  /* Inline code */
  .prose :not(pre) > code { font-family:'JetBrains Mono',monospace; font-size:0.86em; color:#7fe7fb; background:rgba(45,200,235,0.08); border:1px solid rgba(45,200,235,0.14); border-radius:6px; padding:1.5px 6px; }

  /* Code blocks (Shiki) */
  .prose pre { background:#0d0f14 !important; border:1px solid rgba(255,255,255,0.1); border-radius:14px; padding:18px 20px; overflow-x:auto; margin:0 0 20px; font-size:13.5px; line-height:1.7; box-shadow:0 20px 50px -30px rgba(0,0,0,0.7); }
  .prose pre code { font-family:'JetBrains Mono',monospace; background:none; border:none; padding:0; font-size:inherit; color:inherit; }

  /* Tables */
  .prose table { width:100%; border-collapse:collapse; margin:0 0 22px; font-size:14px; display:block; overflow-x:auto; }
  .prose thead { text-align:left; }
  .prose th { font-family:'JetBrains Mono',monospace; font-size:12px; letter-spacing:0.03em; text-transform:uppercase; color:#8b93a1; font-weight:600; padding:10px 14px; border-bottom:1px solid rgba(255,255,255,0.14); white-space:nowrap; }
  .prose td { padding:10px 14px; border-bottom:1px solid rgba(255,255,255,0.06); vertical-align:top; }
  .prose tbody tr:hover { background:rgba(255,255,255,0.02); }

  /* Blockquote → callout */
  .prose blockquote { margin:0 0 20px; padding:14px 18px; border:1px solid rgba(45,200,235,0.22); border-left:3px solid #3dd6f3; border-radius:10px; background:rgba(45,200,235,0.05); color:#b6bdc9; }
  .prose blockquote p { margin:0; }
  .prose blockquote p + p { margin-top:8px; }

  .prose hr { border:none; border-top:1px solid rgba(255,255,255,0.08); margin:40px 0; }

  .prose img { max-width:100%; border-radius:12px; }
</style>

---
import { dict } from "../data/i18n.js";
import { DOCS_URL, DISCORD_URL } from "../data/site.js";
import LangSwitch from "./LangSwitch.astro";
import { Code } from "astro:components";

// "Developer first" code preview — real Shiki highlighting (same engine as the
// docs). Raw Lua strings, so no manual coloring / HTML escaping needed.
const playerControllerLua = `---@param ctx AppContext
return function(ctx)
    local players <const> = ctx.services.player; ---@type PlayerService

    ---@async
    ---@param player Player
    local function spawn(player)
        local account_id <const> = player:GetAccountID();
        local location , rotation = spawn_point.location, spawn_point.rotation;
        local _, character_data <const> = players.load(player, {
            model = default_mesh,
            location = { X = location.X, Y = location.Y, Z = location.Z },
            rotation = { Pitch = rotation.Pitch, Yaw = rotation.Yaw, Roll = rotation.Roll },
        });

        local character <const> = Character(location, rotation, character_data.model, CollisionType.Auto, true, 100);
        player:Possess(character);
        logger:success("spawned player ^y%s^D character's", account_id);
    end

    Player.Subscribe("Spawn", threadify(spawn));
end`;

const playerModelLua = `---@alias PlayerModels { players: NormModel, characters: NormModel }
---@param db NormOrm
---@return PlayerModels
return function(db)
    local players <const> = db:define("players", {
        id        = Norm.types.id(),
        accountId = Norm.types.string({ length = 64, nullable = false, unique = true }),
        character = Norm.types.hasOne("characters", { key = "player_id" }),
    });

    local characters <const> = db:define("characters", {
        id          = Norm.types.id(),
        player_id   = Norm.types.integer({ nullable = false }),
        location    = Norm.types.json({ default = JSON.stringify({ X = 0, Y = 0, Z = 0 }) }),
        rotation    = Norm.types.json({ default = JSON.stringify({ Pitch = 0, Yaw = 0, Roll = 0 }) }),
        model       = Norm.types.string({ length = 64, nullable = false }),
        player      = Norm.types.belongsTo("players", { key = "player_id", onDelete = "CASCADE" }),
    });

    return { players = players, characters = characters };
end`;

interface Props {
    lang?: "fr" | "en";
}
const { lang = "fr" } = Astro.props;
const t = dict[lang];
const isEn = lang === "en";

// Language-switch targets (one static route per language)
const frHref = import.meta.env.BASE_URL; // "/"
const enHref = import.meta.env.BASE_URL.replace(/\/$/, "") + "/en";

// Documentation lives on its own host (docs.nmrp.dev) — cross-domain in production.
const docsHref = isEn
    ? `${DOCS_URL}/en/introduction`
    : `${DOCS_URL}/introduction`;
---

<div class="page">
    <!-- ambient glow -->
    <div class="glow"></div>

    <!-- NAV -->
    <header class="nav">
        <div class="nav-inner">
            <a href="#main-content" class="brand">
                <img
                    src={`${import.meta.env.BASE_URL}logo-64.png`}
                    alt="NoMoreRP"
                    class="brand-logo"
                    width="30"
                    height="30"
                    decoding="async"
                />
                <span class="brand-name"
                    >NoMore<span class="accent">RP</span></span
                >
            </a>
            <nav class="nav-links">
                <a href="#features" class="nav-lnk">{t.nav_features}</a>
                <a href="#api" class="nav-lnk">{t.nav_api}</a>
                <a href="#modules" class="nav-lnk">{t.nav_modules}</a>
                <a href="#install" class="nav-lnk">{t.nav_install}</a>
                <a href={docsHref} class="nav-lnk">{t.nav_docs}</a>
            </nav>
            <div class="nav-right">
                <LangSwitch isEn={isEn} frHref={frHref} enHref={enHref} />
                <a
                    href={DISCORD_URL}
                    target="_blank"
                    rel="noopener"
                    class="icon-lnk icon-discord"
                    aria-label="Discord"
                >
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        aria-hidden="true"
                        ><path
                            d="M20.317 4.3698a19.7913 19.7913 0 0 0-4.8851-1.5152.0741.0741 0 0 0-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 0 0-.0785-.037 19.7363 19.7363 0 0 0-4.8852 1.515.0699.0699 0 0 0-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 0 0 .0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 0 0 .0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 0 0-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 0 1-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 0 1 .0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 0 1 .0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 0 1-.0066.1276 12.2986 12.2986 0 0 1-1.873.8914.0766.0766 0 0 0-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 0 0 .0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 0 0 .0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 0 0-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9554 2.4189-2.1568 2.4189Z"
                        ></path></svg
                    >
                </a>
                <a
                    href="https://github.com/No-More-RP"
                    target="_blank"
                    rel="noopener"
                    class="icon-lnk"
                    aria-label="GitHub"
                >
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        aria-hidden="true"
                        ><path
                            d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.5v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.8 18.3 5 18.3 5c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.6.8.5 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5z"
                        ></path></svg
                    >
                </a>
                <a
                    href="https://github.com/No-More-RP"
                    target="_blank"
                    rel="noopener"
                    class="btn-cyan btn-sm">{t.nav_cta}</a
                >
            </div>
            <button
                class="nav-burger"
                type="button"
                data-nav-burger
                aria-label="Menu"
                aria-expanded="false"
            >
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18" /></svg>
            </button>
        </div>
    </header>

    <!-- HERO -->
    <section id="main-content" tabindex="-1" class="hero">
        <div class="hero-copy">
            <div class="badge">
                <span class="badge-dot"></span>
                {t.hero_badge}
            </div>
            <h1 class="hero-title">
                {t.hero_title_a}
                <span class="accent">{t.hero_title_b}</span>
            </h1>
            <p class="hero-sub">{t.hero_sub}</p>
            <div class="hero-cta">
                <a
                    href="https://github.com/No-More-RP/nmrp"
                    target="_blank"
                    rel="noopener"
                    class="btn-cyan btn-lg"
                >
                    {t.hero_cta1}
                    <svg
                        width="17"
                        height="17"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.4"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><path d="M5 12h14M13 6l6 6-6 6"></path></svg
                    >
                </a>
                <a href={docsHref} class="btn-ghost">{t.hero_cta2}</a>
            </div>
            <a
                href="https://github.com/No-More-RP/nmrp"
                target="_blank"
                rel="noopener"
                class="gh-stars"
                data-gh-stars-link
                hidden
            >
                <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.5l2.9 6 6.6.9-4.8 4.6 1.2 6.5L12 18.9 6.1 21l1.2-6.5L2.5 9.9l6.6-.9z"/></svg>
                <b data-gh-stars></b>
                <span>{isEn ? "stars on GitHub" : "stars sur GitHub"}</span>
            </a>
            <div class="stats">
                {
                    t.stats.map((s) => (
                        <div>
                            <div class="stat-value">{s.value}</div>
                            <div class="stat-label">{s.label}</div>
                        </div>
                    ))
                }
            </div>
        </div>

        <!-- Terminal window -->
        <div class="term-float">
            <div class="term">
                <div class="term-bar">
                    <span class="dot" style="background:#ff5f57;"></span>
                    <span class="dot" style="background:#febc2e;"></span>
                    <span class="dot" style="background:#28c840;"></span>
                    <span class="term-title">nanos-world-server — Packages</span
                    >
                </div>
                <pre
                    class="term-body"><span class="c-dim"># {t.term_comment}</span>
Packages/
  <span class="c-blue">nmrp/</span>            <span class="c-dim">MVC gamemode base</span>
  <span class="c-blue">nmrp-rpc/</span>        <span class="c-dim">typed RPC layer</span>
  <span class="c-blue">nmrp-norm/</span>       <span class="c-dim">Norm ORM</span>
  <span class="c-blue">nmrp-promise/</span>    <span class="c-dim">async / promises</span>

<span class="c-dim"># nmrp/Package.toml</span>
<span class="c-purple">name</span>     = <span class="c-cyan">"nmrp"</span>
<span class="c-purple">title</span>    = <span class="c-cyan">"NoMoreRP"</span>
<span class="c-purple">type</span>     = <span class="c-cyan">"game-mode"</span>

<span class="c-accent">▶</span> {t.term_ready} <span class="cursor">▋</span></pre>
            </div>
        </div>
    </section>

    <!-- trust strip -->
    <div class="trust-wrap">
        <p class="trust-label">{t.trust}</p>
        <div class="trust-logos">
            <span>MIT</span><span>Lua&nbsp;+&nbsp;TypeScript</span><span
                >Async&nbsp;MySQL</span
            ><span>nanos-world</span><span>Hot&nbsp;reload</span>
        </div>
    </div>

    <!-- FEATURES -->
    <section id="features" class="section" data-reveal>
        <div class="section-head">
            <p class="eyebrow">{t.feat_eyebrow}</p>
            <h2 class="h2">{t.feat_title}</h2>
            <p class="lead">{t.feat_sub}</p>
        </div>
        <div class="grid-4">
            {
                t.features.map((f) => (
                    <div class="feat-card">
                        <div class="feat-icon">
                            <svg
                                width="21"
                                height="21"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="#3dd6f3"
                                stroke-width="1.8"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                            >
                                <path d={f.d} />
                            </svg>
                        </div>
                        <h3 class="feat-title">{f.title}</h3>
                        <p class="feat-desc">{f.desc}</p>
                    </div>
                ))
            }
        </div>
    </section>

    <!-- API / CODE -->
    <section id="api" class="section" data-reveal>
        <div class="api-grid">
            <div>
                <p class="eyebrow">{t.api_eyebrow}</p>
                <h2 class="h2 h2-left">{t.api_title}</h2>
                <p class="lead lead-left">{t.api_sub}</p>
                <ul class="api-points">
                    {
                        t.api_points.map((p) => (
                            <li>
                                <svg
                                    width="19"
                                    height="19"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="#3dd6f3"
                                    stroke-width="2.4"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                >
                                    <path d="M20 6L9 17l-5-5" />
                                </svg>
                                {p}
                            </li>
                        ))
                    }
                </ul>
            </div>
            <div class="code" data-tabs>
                <div class="code-tabs" role="tablist">
                    <button
                        class="tab tab-active"
                        type="button"
                        data-tab="0"
                        role="tab"
                        aria-selected="true">player.controller.lua</button
                    >
                    <button
                        class="tab"
                        type="button"
                        data-tab="1"
                        role="tab"
                        aria-selected="false">player.model.lua</button
                    >
                </div>
                <div class="code-body" data-panel="0">
                    <Code
                        code={playerControllerLua}
                        lang="lua"
                        theme="one-dark-pro"
                    />
                </div>
                <div class="code-body" data-panel="1" hidden>
                    <Code
                        code={playerModelLua}
                        lang="lua"
                        theme="one-dark-pro"
                    />
                </div>
            </div>
        </div>
    </section>

    <!-- ARCHITECTURE -->
    <section id="architecture" class="section" data-reveal>
        <div class="section-head">
            <p class="eyebrow">Architecture</p>
            <h2 class="h2">{isEn ? "MVC, wired for you" : "Le MVC, câblé pour toi"}</h2>
            <p class="lead">
                {
                    isEn
                        ? "A loader boots everything and a DI registry wires your models, views and controllers — on top of dependency-free packages."
                        : "Un loader démarre tout et un registre DI relie tes modèles, vues et contrôleurs — posés sur des packages sans dépendances."
                }
            </p>
        </div>

        <div class="arch">
            <!-- Layer 1: your MVC modules -->
            <div class="arch-layer">
                <span class="arch-tag">{isEn ? "Your modules" : "Tes modules"}</span>
                <div class="arch-mvc">
                    <div class="arch-cell">
                        <svg viewBox="0 0 24 24" fill="none" stroke="#3dd6f3" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3c4.4 0 8 1.3 8 3s-3.6 3-8 3-8-1.3-8-3 3.6-3 8-3z"/><path d="M4 6v12c0 1.7 3.6 3 8 3s8-1.3 8-3V6"/><path d="M4 12c0 1.7 3.6 3 8 3s8-1.3 8-3"/></svg>
                        <b>Model</b><span>{isEn ? "data · Norm ORM" : "données · Norm ORM"}</span>
                    </div>
                    <div class="arch-cell">
                        <svg viewBox="0 0 24 24" fill="none" stroke="#3dd6f3" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="13" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
                        <b>View</b><span>WebUI · HUD</span>
                    </div>
                    <div class="arch-cell">
                        <svg viewBox="0 0 24 24" fill="none" stroke="#3dd6f3" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 6h16M4 12h16M4 18h16"/><circle cx="8" cy="6" r="1.6" fill="#3dd6f3" stroke="none"/><circle cx="15" cy="12" r="1.6" fill="#3dd6f3" stroke="none"/><circle cx="10" cy="18" r="1.6" fill="#3dd6f3" stroke="none"/></svg>
                        <b>Controller</b><span>{isEn ? "engine wiring" : "câblage moteur"}</span>
                    </div>
                </div>
            </div>

            <div class="arch-conn" aria-hidden="true">
                <svg viewBox="0 0 24 34" fill="none" stroke="#3dd6f3" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v26"/><path d="M6 22l6 6 6-6"/></svg>
            </div>

            <!-- Layer 2: nmrp core -->
            <div class="arch-layer arch-core">
                <span class="arch-tag arch-tag-core">nmrp · core</span>
                <div class="arch-core-row">
                    <span class="arch-chip">Loader</span>
                    <svg class="arch-rarrow" viewBox="0 0 34 24" fill="none" stroke="#3dd6f3" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 12h26"/><path d="M22 6l6 6-6 6"/></svg>
                    <span class="arch-chip">DI Registry</span>
                </div>
                <p class="arch-note">
                    {
                        isEn
                            ? "resolves services & wires every module in dependency order"
                            : "résout les services & câble chaque module dans l’ordre des dépendances"
                    }
                </p>
            </div>

            <div class="arch-conn" aria-hidden="true">
                <svg viewBox="0 0 24 34" fill="none" stroke="#3dd6f3" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v26"/><path d="M6 22l6 6 6-6"/></svg>
            </div>

            <!-- Layer 3: packages -->
            <div class="arch-layer">
                <span class="arch-tag">{isEn ? "Dependency-free Lua packages" : "Packages Lua sans dépendances"}</span>
                <div class="arch-pkgs">
                    <div class="arch-pkg"><b>nmrp-promise</b><span>async</span></div>
                    <div class="arch-pkg"><b>nmrp-norm</b><span>ORM</span></div>
                    <div class="arch-pkg"><b>nmrp-rpc</b><span>RPC</span></div>
                    <div class="arch-pkg"><b>nmrp-locale</b><span>i18n</span></div>
                </div>
            </div>
        </div>
    </section>

    <!-- MODULES -->
    <section id="modules" class="section" data-reveal>
        <div class="section-head">
            <p class="eyebrow">{t.mod_eyebrow}</p>
            <h2 class="h2">{t.mod_title}</h2>
            <p class="lead">{t.mod_sub}</p>
        </div>
        <div class="grid-3">
            {
                t.modules.map((m) => (
                    <div class="mod-card">
                        <div class="mod-head">
                            <span class="mod-pkg">{m.pkg}</span>
                            <span class="mod-tag">{m.tag}</span>
                        </div>
                        <p class="mod-desc">{m.desc}</p>
                    </div>
                ))
            }
        </div>
    </section>

    <!-- INSTALL -->
    <section id="install" class="section section-narrow" data-reveal>
        <div class="section-head">
            <p class="eyebrow">{t.ins_eyebrow}</p>
            <h2 class="h2">{t.ins_title}</h2>
            <p class="lead">{t.ins_sub}</p>
        </div>
        <div class="qs-grid">
            <ol class="qs-steps">
                {
                    t.steps.map((st) => (
                        <li class="qs-step">
                            <span class="qs-n">{st.n}</span>
                            <div>
                                <h3 class="qs-title">{st.title}</h3>
                                <p class="qs-desc">{st.desc}</p>
                            </div>
                        </li>
                    ))
                }
            </ol>

            <div class="term qs-term">
                <div class="term-bar">
                    <span class="dot" style="background:#ff5f57;"></span>
                    <span class="dot" style="background:#febc2e;"></span>
                    <span class="dot" style="background:#28c840;"></span>
                    <span class="term-title">nmrp — quickstart</span>
                </div>
                <pre
                    class="term-body"><span class="c-dim"># 1 · drop the packages into your server</span>
cd Packages/
git clone --recursive <span class="c-blue">.../No-More-RP/nmrp</span>
git clone --recursive <span class="c-blue">.../nmrp-promise nmrp-norm</span>
git clone <span class="c-blue">.../nmrp-rpc nmrp-locale</span>

<span class="c-dim"># 2 · enable it — Config.toml</span>
<span class="c-purple">[game]</span>
  <span class="c-purple">game_mode</span> = <span class="c-cyan">"nmrp"</span>

<span class="c-dim"># 3 · point it at your database</span>
<span class="c-purple">database_connection</span> = <span class="c-cyan">"db=nmrp user=root ..."</span>

<span class="c-dim"># 4 · launch</span>
<span class="c-accent">▶</span> ./NanosWorldServer.exe <span class="cursor">▋</span></pre>
            </div>
        </div>
    </section>

    <!-- COMMUNITY CTA -->
    <section class="section cta-section" data-reveal>
        <div class="cta-box">
            <div class="cta-glow"></div>
            <div class="cta-inner">
                <h2 class="h2">{t.cta_title}</h2>
                <p class="cta-sub">{t.cta_sub}</p>
                <div class="cta-btns">
                    <a
                        href="https://github.com/orgs/No-More-RP/discussions"
                        target="_blank"
                        rel="noopener"
                        class="btn-cyan btn-lg"
                    >
                        <svg
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path
                                d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                            ></path></svg
                        >
                        {t.cta_discord}
                    </a>
                    <a
                        href="https://github.com/No-More-RP"
                        target="_blank"
                        rel="noopener"
                        class="btn-ghost btn-lg"
                    >
                        <svg
                            width="19"
                            height="19"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            ><path

---
import {
  ORG,
  FALLBACK_REPOS,
  TEAM,
  ROLE_PRIORITY,
} from '../data/contributors.js';

interface Props {
  lang?: 'fr' | 'en';
}
const { lang = 'fr' } = Astro.props;

const copy = {
  fr: {
    intro:
      'NoMoreRP est construit par sa communauté. Merci à toutes les personnes qui contribuent au code, à la documentation et aux idées de l’écosystème.',
    count: (n) => `${n} contributeur${n > 1 ? 's' : ''}`,
    contributions: 'contributions',
    loading: 'Chargement des contributeurs…',
    empty: 'Impossible de charger les contributeurs pour le moment.',
    seeGh: 'Voir sur GitHub',
    roles: { core: 'Core team', maintainer: 'Mainteneur' },
  },
  en: {
    intro:
      'NoMoreRP is built by its community. Thanks to everyone contributing code, documentation and ideas across the ecosystem.',
    count: (n) => `${n} contributor${n > 1 ? 's' : ''}`,
    contributions: 'contributions',
    loading: 'Loading contributors…',
    empty: 'Couldn’t load contributors right now.',
    seeGh: 'See them on GitHub',
    roles: { core: 'Core team', maintainer: 'Maintainer' },
  },
}[lang];

// Sent to the client script (all public data).
const config = {
  org: ORG,
  fallbackRepos: FALLBACK_REPOS,
  team: TEAM,
  rolePriority: ROLE_PRIORITY,
  contributions: copy.contributions,
  roles: copy.roles,
  empty: copy.empty,
  seeGh: copy.seeGh,
  countOne: copy.count(1),
  countMany: copy.count(2),
};
---

<p class="contrib-intro">{copy.intro}</p>
<p class="contrib-count" data-contrib-count hidden></p>
<div data-contrib-list>
  <p class="contrib-loading">{copy.loading}</p>
</div>

<style is:global>
  .contrib-intro {
    color: #b6bdc9;
    font-size: 16px;
    line-height: 1.6;
    max-width: 640px;
    margin: 0 0 24px;
  }
  .contrib-count {
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #6b7280;
    margin: 0 0 16px;
  }
  .contrib-loading {
    color: #7b8290;
    font-size: 14px;
  }
  .contrib-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 12px;
  }
  .contrib-grid li {
    margin: 0;
    padding: 0;
  }
  .contrib-card {
    display: flex;
    align-items: center;
    gap: 13px;
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.02);
    border-radius: 12px;
    padding: 12px 14px;
    transition:
      border-color 0.15s,
      background 0.15s,
      transform 0.15s;
  }
  .contrib-card:hover {
    border-color: rgba(45, 200, 235, 0.4);
    background: rgba(45, 200, 235, 0.04);
    transform: translateY(-2px);
  }
  .contrib-av {
    width: 46px;
    height: 46px;
    border-radius: 50%;
    flex-shrink: 0;
    margin: 0;
    background: #0d0f14;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.1);
  }
  .contrib-info {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .contrib-namerow {
    display: flex;
    align-items: center;
    gap: 7px;
    min-width: 0;
  }
  .contrib-name {
    font-family: "Inter", sans-serif;
    font-weight: 600;
    font-size: 14.5px;
    color: #e7e9ee;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .contrib-badge {
    flex-shrink: 0;
    font-family: "JetBrains Mono", monospace;
    font-size: 9.5px;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    padding: 2px 6px;
    border-radius: 5px;
    line-height: 1.4;
  }
  .role-core {
    color: #3dd6f3;
    background: rgba(45, 200, 235, 0.12);
    border: 1px solid rgba(45, 200, 235, 0.32);
  }
  .role-maintainer {
    color: #c084fc;
    background: rgba(192, 132, 252, 0.12);
    border: 1px solid rgba(192, 132, 252, 0.32);
  }
  .contrib-meta {
    font-size: 12px;
    color: #7b8290;
  }
  .contrib-empty {
    color: #b6bdc9;
  }
</style>

<script define:vars={{ cfg: config }}>
  const CACHE_KEY = "nmrp:contributors";
  const TTL = 24 * 60 * 60 * 1000; // 24h

  const listEl = document.querySelector("[data-contrib-list]");
  const countEl = document.querySelector("[data-contrib-count]");
  if (listEl) init();

  async function init() {
    let data = readCache();
    if (!data) {
      data = await fetchAll();
      if (data && data.length) writeCache(data);
    }
    render(data || []);
  }

  function readCache() {
    try {
      const raw = localStorage.getItem(CACHE_KEY);
      if (!raw) return null;
      const { t, data } = JSON.parse(raw);
      if (Date.now() - t < TTL && Array.isArray(data) && data.length)
        return data;
    } catch (e) {}
    return null;
  }
  function writeCache(data) {
    try {
      localStorage.setItem(CACHE_KEY, JSON.stringify({ t: Date.now(), data }));
    } catch (e) {}
  }

  async function fetchAll() {
    let repos = [];
    try {
      const r = await fetch(
        `https://api.github.com/orgs/${cfg.org}/repos?per_page=100&type=public`,
      );
      if (r.ok) {
        const l = await r.json();
        if (Array.isArray(l)) repos = l.filter((x) => !x.fork).map((x) => x.name);
      }
    } catch (e) {}
    if (!repos.length) repos = cfg.fallbackRepos;

    const byLogin = new Map();
    await Promise.all(
      repos.map(async (repo) => {
        try {
          const r = await fetch(
            `https://api.github.com/repos/${cfg.org}/${repo}/contributors?per_page=100`,
          );
          if (!r.ok) return;
          const list = await r.json();
          if (!Array.isArray(list)) return;
          for (const c of list) {
            if (c.type !== "User") continue;
            const cur = byLogin.get(c.login) || {
              login: c.login,
              avatar: c.avatar_url,
              url: c.html_url,
              contributions: 0,
              role: cfg.team[c.login.toLowerCase()] || null,
            };
            cur.contributions += c.contributions || 0;
            byLogin.set(c.login, cur);
          }
        } catch (e) {}
      }),
    );

    const rank = (role) => (role in cfg.rolePriority ? cfg.rolePriority[role] : 99);
    return [...byLogin.values()].sort((a, b) => {
      const d = rank(a.role) - rank(b.role);
      return d !== 0 ? d : b.contributions - a.contributions;
    });
  }

  function esc(s) {
    return String(s).replace(
      /[&<>"']/g,
      (c) =>
        ({
          "&": "&amp;",
          "<": "&lt;",
          ">": "&gt;",
          '"': "&quot;",
          "'": "&#39;",
        })[c],
    );
  }

  function render(data) {
    if (!data.length) {
      listEl.innerHTML =
        `<p class="contrib-empty">${cfg.empty} ` +
        `<a href="https://github.com/${cfg.org}" target="_blank" rel="noopener">${cfg.seeGh}</a></p>`;
      return;
    }
    if (countEl) {
      countEl.textContent =
        data.length > 1
          ? cfg.countMany.replace(/\d+/, data.length)
          : cfg.countOne;
      countEl.hidden = false;
    }
    listEl.innerHTML =
      '<ul class="contrib-grid">' +
      data
        .map((c) => {
          const badge = c.role
            ? `<span class="contrib-badge role-${c.role}">${cfg.roles[c.role] || c.role}</span>`
            : "";
          const av = `${c.avatar}${c.avatar.includes("?") ? "&" : "?"}s=96`;
          return (
            `<li><a href="${esc(c.url)}" target="_blank" rel="noopener" class="contrib-card">` +
            `<img src="${esc(av)}" alt="${esc(c.login)}" width="46" height="46" loading="lazy" class="contrib-av">` +
            `<span class="contrib-info"><span class="contrib-namerow">` +
            `<span class="contrib-name">${esc(c.login)}</span>${badge}</span>` +
            `<span class="contrib-meta">${c.contributions} ${esc(cfg.contributions)}</span>` +
            `</span></a></li>`
          );
        })
        .join("") +
      "</ul>";
  }
</script>

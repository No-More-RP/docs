---
import { docsUi } from '../data/docs-nav.js';

interface Props {
  lang?: 'fr' | 'en';
}
const { lang = 'fr' } = Astro.props;
const ui = docsUi[lang];

// Pagefind UI strings (its runtime substitutes [SEARCH_TERM]).
const translations = {
  placeholder: ui.searchPlaceholder,
  clear_search: lang === 'fr' ? 'Effacer' : 'Clear',
  load_more: lang === 'fr' ? 'Voir plus' : 'Load more',
  search_label: ui.searchPlaceholder,
  zero_results:
    lang === 'fr'
      ? 'Aucun résultat pour [SEARCH_TERM]'
      : 'No results for [SEARCH_TERM]',
  many_results:
    lang === 'fr'
      ? '[COUNT] résultats pour [SEARCH_TERM]'
      : '[COUNT] results for [SEARCH_TERM]',
  one_result:
    lang === 'fr'
      ? '[COUNT] résultat pour [SEARCH_TERM]'
      : '[COUNT] result for [SEARCH_TERM]',
  searching:
    lang === 'fr' ? 'Recherche…' : 'Searching…',
};
---

<button class="search-btn" type="button" aria-label={ui.searchPlaceholder} data-search-open>
  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7" /><path d="m21 21-4.3-4.3" /></svg>
  <span class="search-btn-label">{ui.searchPlaceholder}</span>
  <kbd class="search-kbd"><span data-search-mod>Ctrl</span> K</kbd>
</button>

<div class="search-modal" data-search-modal hidden>
  <div class="search-backdrop" data-search-close></div>
  <div class="search-panel" role="dialog" aria-modal="true" aria-label={ui.searchPlaceholder}>
    <div id="search"></div>
  </div>
</div>

<style>
  .search-btn {
    display: flex;
    align-items: center;
    gap: 9px;
    cursor: pointer;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 9px;
    color: #7b8290;
    padding: 7px 10px;
    font-family: "Inter", sans-serif;
    font-size: 13px;
    transition:
      border-color 0.15s,
      background 0.15s,
      color 0.15s;
  }
  .search-btn:hover {
    border-color: rgba(45, 200, 235, 0.4);
    background: rgba(45, 200, 235, 0.05);
    color: #e7e9ee;
  }
  .search-btn-label {
    min-width: 88px;
    text-align: left;
  }
  .search-kbd {
    font-family: "JetBrains Mono", monospace;
    font-size: 10.5px;
    color: #6b7280;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 5px;
    padding: 1px 5px;
    line-height: 1.4;
    white-space: nowrap;
  }

  .search-modal {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding: 12vh 20px 20px;
  }
  .search-modal[hidden] {
    display: none;
  }
  .search-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(4, 5, 7, 0.6);
    backdrop-filter: blur(6px);
  }
  .search-panel {
    position: relative;
    width: min(640px, 100%);
    background: #0d0f14;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 14px;
    box-shadow: 0 30px 70px -20px rgba(0, 0, 0, 0.7);
    overflow: hidden;
  }

  /* Pagefind UI theming (variables cascade into its injected DOM). */
  #search {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: #3dd6f3;
    --pagefind-ui-text: #e7e9ee;
    --pagefind-ui-background: #0d0f14;
    --pagefind-ui-border: rgba(255, 255, 255, 0.1);
    --pagefind-ui-tag: rgba(255, 255, 255, 0.05);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 10px;
    --pagefind-ui-font: "Inter", system-ui, sans-serif;
    padding: 14px;
  }
  /* Keep the input pinned; scroll only the results. */
  #search :global(.pagefind-ui__drawer) {
    max-height: 56vh;
    overflow-y: auto;
    margin-top: 6px;
  }
  #search :global(.pagefind-ui__result) {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }
  .search-dev {
    padding: 24px 4px;
    text-align: center;
    color: #7b8290;
    font-size: 14px;
  }

  @media (max-width: 820px) {
    .search-btn-label,
    .search-kbd {
      display: none;
    }
    .search-btn {
      padding: 8px;
    }
  }
</style>

<script define:vars={{ translations }}>
  const modal = document.querySelector("[data-search-modal]");
  if (modal) {
    const mount = modal.querySelector("#search");
    const openEls = document.querySelectorAll("[data-search-open]");
    const closeEls = document.querySelectorAll("[data-search-close]");
    let inited = false;

    // Show the right shortcut symbol per platform.
    const isMac = /mac|iphone|ipad|ipod/i.test(navigator.platform || navigator.userAgent);
    document.querySelectorAll("[data-search-mod]").forEach((el) => {
      el.textContent = isMac ? "⌘" : "Ctrl";
    });

    function loadScript(src) {
      return new Promise((resolve, reject) => {
        const s = document.createElement("script");
        s.src = src;
        s.onload = resolve;
        s.onerror = reject;
        document.head.appendChild(s);
      });
    }

    async function init() {
      if (inited) return;
      inited = true;
      // pagefind-ui.js is a classic IIFE that sets window.PagefindUI —
      // it must be loaded as a <script>, not imported as an ES module.
      const css = document.createElement("link");
      css.rel = "stylesheet";
      css.href = "/pagefind/pagefind-ui.css";
      document.head.appendChild(css);
      try {
        await loadScript("/pagefind/pagefind-ui.js");
        if (!window.PagefindUI) throw new Error("PagefindUI missing");
        new window.PagefindUI({
          element: "#search",
          showImages: false,
          showSubResults: true,
          resetStyles: false,
          translations,
        });
      } catch (e) {
        mount.innerHTML =
          '<p class="search-dev">Search is generated at build time — run a production build to try it.</p>';
      }
    }

    function open() {
      modal.hidden = false;
      document.body.style.overflow = "hidden";
      init().then(() => {
        const input = modal.querySelector("input");
        if (input) input.focus();
      });
    }
    function close() {
      modal.hidden = true;
      document.body.style.overflow = "";
    }

    openEls.forEach((el) => el.addEventListener("click", open));
    closeEls.forEach((el) => el.addEventListener("click", close));

    document.addEventListener("keydown", (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k") {
        e.preventDefault();
        modal.hidden ? open() : close();
      } else if (e.key === "Escape" && !modal.hidden) {
        close();
      }
    });
  }
</script>

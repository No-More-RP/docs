# Copy this file to `.env` and fill in the values.
#
# GitHub token used ONLY at build time to fetch the contributors list
# (aggregated across the No-More-RP org). It lifts the GitHub API rate limit
# from 60 to 5000 requests/hour, so the contributors page reliably populates.
#
# A fine-grained Personal Access Token with read-only access to PUBLIC
# repositories is enough — no write scopes needed.
# Optional: builds work unauthenticated too, until the 60/h limit is reached.
GITHUB_TOKEN=
